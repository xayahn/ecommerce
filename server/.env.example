# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Client ────────────────────────────────────────────────────────────────────
# URL of your React frontend (used in CORS)
CLIENT_ORIGIN=https://your-frontend-domain.onrender.com

# ─── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Local:  postgresql://postgres:yourpassword@localhost:5432/shopify_store?schema=public
# Neon:   postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/shopify_store?sslmode=require
DATABASE_URL="postgresql://admin123@localhost:5432/shopify_store?schema=public"

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string_minimum_32_characters
JWT_EXPIRES_IN=7d

# ─── Security ──────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12